#:kivy 2.2.0

#:import Factory kivy.factory.Factory

<MainScreen>:
    name: 'main'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10

        # Header
        Label:
            text: 'TV Box Manager'
            font_size: '42sp' if root.is_phone_mode else '48sp'
            size_hint_y: 0.12 if root.is_phone_mode else 0.15
            halign: 'center'

        # Storage status
        BoxLayout:
            size_hint_y: 0.06
            spacing: 10
            Label:
                id: usb_status
                text: 'Storage: ' + (root.usb_path if root.usb_path else 'Not Found')
                font_size: '18sp' if root.is_phone_mode else '24sp'
                halign: 'center'
                color: (0, 1, 0, 1) if root.usb_path else (1, 0.5, 0, 1)

        # Type indicator
        Label:
            text: '[color=88aaff]Device: ' + ('Phone Mode' if root.is_phone_mode else 'TV Mode') + '[/color]'
            font_size: '14sp'
            size_hint_y: 0.04
            markup: True
            halign: 'center'

        # App list
        GridLayout:
            cols: 1
            size_hint_y: 0.58 if root.is_phone_mode else 0.55
            spacing: 10

            ScrollView:
                do_scroll_x: False

                GridLayout:
                    id: app_list
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

        # Bottom buttons
        BoxLayout:
            size_hint_y: 0.15 if root.is_phone_mode else 0.12
            spacing: 15
            padding: 10
            orientation: 'vertical'

            # Main action buttons
            BoxLayout:
                spacing: 20

                Button:
                    text: 'Refresh'
                    font_size: '20sp' if root.is_phone_mode else '24sp'
                    on_press: root.refresh_apps()

                Button:
                    text: 'Browse...'
                    font_size: '20sp' if root.is_phone_mode else '24sp'
                    on_press: root.browse_folder()

            # Secondary buttons
            BoxLayout:
                spacing: 20

                Button:
                    text: 'Install All'
                    font_size: '18sp' if root.is_phone_mode else '22sp'
                    on_press: app.root.current = 'install'

                Button:
                    text: 'Settings'
                    font_size: '18sp' if root.is_phone_mode else '22sp'
                    on_press: app.root.current = 'settings'

<InstallScreen>:
    name: 'install'
    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15

        Label:
            text: 'Installing Apps...'
            font_size: '36sp'
            size_hint_y: 0.25

        Label:
            id: current_app
            text: root.current_app
            font_size: '24sp'
            size_hint_y: 0.2
            text_size: self.size
            halign: 'center'

        Label:
            id: install_status
            text: root.install_status
            font_size: '28sp'
            size_hint_y: 0.35
            text_size: self.size
            halign: 'center'

        BoxLayout:
            size_hint_y: 0.2

            Button:
                text: 'Install All from Storage'
                font_size: '22sp'
                on_press: root.install_all()

        Button:
            text: 'Back to Main'
            font_size: '24sp'
            size_hint_y: 0.15
            on_press: app.root.current = 'main'

<InstalledAppsScreen>:
    name: 'installed'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10

        Label:
            text: 'Installed Apps'
            font_size: '36sp'
            size_hint_y: 0.12

        ScrollView:
            size_hint_y: 0.73

            GridLayout:
                id: installed_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 3

        Button:
            text: 'Back'
            font_size: '24sp'
            size_hint_y: 0.12
            on_press: app.root.current = 'main'

<SettingsScreen>:
    name: 'settings'
    BoxLayout:
        orientation: 'vertical'
        padding: 25
        spacing: 15

        Label:
            text: 'Settings'
            font_size: '38sp'
            size_hint_y: 0.1

        # Device info section
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.25
            padding: 15

            Label:
                text: '[b]Device Information[/b]'
                markup: True
                font_size: '20sp'
                size_hint_y: 0.3

            Label:
                text: 'Type: ' + root.device_type
                font_size: '18sp'
                size_hint_y: 0.35
                halign: 'left'

            Label:
                text: 'Apps Folder: ' + root.apps_folder
                font_size: '16sp'
                size_hint_y: 0.35
                halign: 'left'

        # Storage locations section
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.4
            padding: 15

            Label:
                text: '[b]Available Storage Locations[/b]'
                markup: True
                font_size: '20sp'
                size_hint_y: 0.15

            ScrollView:
                size_hint_y: 0.85

                GridLayout:
                    id: storage_list
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

        # About section
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.15
            Label:
                text: 'TV Box Manager v1.1\nSupports Android TV & Phone'
                font_size: '14sp'
                halign: 'center'

        Button:
            text: 'Back to Main'
            font_size: '24sp'
            size_hint_y: 0.1
            on_press: app.root.current = 'main'
